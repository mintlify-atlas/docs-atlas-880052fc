  "keyFeatures": [
    "Type-safe custom connector authoring with actions, triggers, data sources, and connections",
    "Code-native integration definitions with flows and config wizards",
    "OAuth 2.0 and on-prem connection support",
    "Built-in HTTP client with retry logic and automatic authorization",
    "Testing utilities for unit testing actions, triggers, data sources, and flows",
    "Comprehensive type coercion utilities (util.types)",
    "Polling trigger support with scheduled execution",
    "Branching and conditional logic in actions",
    "Component manifest support for referencing existing Prismatic components"
  ],
  "publicApiSurface": [
    "component(definition: ComponentDefinition)",
    "action(definition: ActionDefinition)",
    "trigger(definition: TriggerDefinition)",
    "pollingTrigger(definition: PollingTriggerDefinition)",
    "dataSource(definition: DataSourceDefinition)",
    "input(definition: InputFieldDefinition)",
    "connection(definition: DefaultConnectionDefinition)",
    "oauth2Connection(definition: OAuth2ConnectionDefinition)",
    "onPremConnection(definition: OnPremConnectionDefinition)",
    "integration(definition: IntegrationDefinition)",
    "flow(definition: Flow)",
    "configPage(definition: ConfigPage)",
    "configVar(definition: StandardConfigVar)",
    "connectionConfigVar(definition: ConnectionConfigVar)",
    "dataSourceConfigVar(definition: DataSourceConfigVar)",
    "componentManifest(definition: ComponentManifest)",
    "customerActivatedConnection(definition)",
    "organizationActivatedConnection(definition)",
    "util.types.toBool / isBool",
    "util.types.toInt / isInt",
    "util.types.toNumber / isNumber",
    "util.types.toString / isString",
    "util.types.toDate / isDate",
    "util.types.toJSON / isJSON",
    "util.types.toBufferDataPayload / isBufferDataPayload",
    "util.types.keyValPairListToObject",
    "util.types.isConnection",
    "util.types.cleanObject",
    "testing.invoke(action, params, context)",
    "testing.invokeTrigger(trigger, context, payload, params)",
    "testing.invokeDataSource(dataSource, params, context)",
    "testing.invokeFlow(flow, options)",
    "testing.createHarness(component)",
    "testing.createConnection(definition, values)",
    "testing.loggerMock()",
    "SpectralError",
    "ConnectionError"
  ]
}
